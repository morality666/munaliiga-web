# Community links
VITE_DISCORD_URL=https://discord.gg/Nd75KFMAQt
VITE_YOUTUBE_URL=https://www.youtube.com/@morality666

# Current season and player registration
VITE_SEASON_NUMBER=3
#If this is left empty, it will use the VITE_SIGNUP_OPENS_AT to schedule signup opening.
VITE_SIGNUPS_OPEN=true
# ISO 8601 date format, e.g. 2026-08-01T18:00:00+03:00
VITE_SIGNUP_OPENS_AT=2026-07-10T20:15:00+03:00
# Main-page signup links. VITE_SIGNUP_URL is still used by the top-right header link.
VITE_PLAYER_SIGNUP_URL=https://forms.gle/YujG7u59VJGJ3jzE6
VITE_COACH_SIGNUP_URL=https://forms.gle/iwkj5Hziw6d83Kyr8
# Top right corner signup link. You can leave this empty if you just want it to be text.
VITE_SIGNUP_URL=https://forms.gle/YujG7u59VJGJ3jzE6

# Comma-separated Twitch channels. morality666 is always the main caster. Separate by comma when adding more.
VITE_TWITCH_CHANNELS=morality666
# Comma-separated domains Twitch is allowed to be embedded on. No https:// or paths needed.
VITE_TWITCH_PARENT_DOMAINS=munaliiga.fi,www.munaliiga.fi,localhost,127.0.0.1
